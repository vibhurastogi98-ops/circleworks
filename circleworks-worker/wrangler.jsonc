{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "circleworks-worker",
	"main": "src/index.ts",
	"compatibility_date": "2026-04-05",
	"observability": {
		"enabled": true
	},
	"upload_source_maps": true,
	"compatibility_flags": [
		"nodejs_compat"
	],
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "circleworks-db",
			"database_id": "c05ac165-a394-471a-81e3-8d14d0391979"
		}
	]
}